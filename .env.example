# mail-assistant — miljøvariabler
# Kopiér til .env og udfyld — .env må ALDRIG committes til Git

# ── IMAP ──────────────────────────────────────────────────────────────────────
IMAP_HOST=mail.dinserver.dk
IMAP_PORT=993
IMAP_USER=din@email.dk
IMAP_PASSWORD=dit-password
IMAP_FOLDER=INBOX

# Præfiks foran mappenavne på IMAP-serveren.
# Tom = mapper i roden (Dovecot standard).
# "INBOX." = undermapper under INBOX (cPanel/Plesk).
IMAP_FOLDER_PREFIX=

# Arkivmappe til auto-completion (se COMPLETE_ON_ARCHIVED nedenfor).
# Præfikset fra IMAP_FOLDER_PREFIX tilføjes automatisk.
IMAP_ARCHIVE_FOLDER=Archive

# ── LLM provider ──────────────────────────────────────────────────────────────
# Vælg én: ollama | anthropic | mistral | claude-code
LLM_PROVIDER=ollama

# Timeout i sekunder — gælder alle providers. Sæt højt på langsom hardware.
LLM_TIMEOUT=600

# Antal mails per LLM-kald.
# 1 = én mail ad gangen (standard, bagud-kompatibel).
# >1 = batch — hurtigere ved API-providers, kræver at LLM kan returnere JSON array.
LLM_BATCH_SIZE=1

# Debug-tilstand: logger LLM-prompts og råsvar til konsol (meget verbose).
# Sæt til "true" ved fejlfinding, hold "false" i produktion.
LLM_DEBUG=false

# ── Ollama (lokal) ────────────────────────────────────────────────────────────
# Bruges når LLM_PROVIDER=ollama
OLLAMA_HOST=http://ollama:11434

# Model — mindre = hurtigere men dårligere kvalitet
# qwen2.5:0.5b  — hurtigst, begrænset kvalitet
# qwen2.5:1.5b  — kompromis
# qwen2.5:3b    — bedre kvalitet, langsom på svag hardware
OLLAMA_MODEL=qwen2.5:0.5b

# Context window — 2048 er rigeligt til mails. Lavere = hurtigere + mindre RAM.
OLLAMA_NUM_CTX=2048

# CPU tråde — sæt til antal fysiske kerner på serveren.
OLLAMA_NUM_THREAD=2

# ── Anthropic (Claude API) ────────────────────────────────────────────────────
# Bruges når LLM_PROVIDER=anthropic
# API-nøgle fra https://console.anthropic.com
ANTHROPIC_API_KEY=

# Anbefalede modeller (billigst til dyrest):
# claude-haiku-4-5-20251001  — hurtig og billig, god til klassificering
# claude-sonnet-4-6          — bedre kvalitet
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Mistral API ───────────────────────────────────────────────────────────────
# Bruges når LLM_PROVIDER=mistral
# API-nøgle fra https://console.mistral.ai
MISTRAL_API_KEY=

# Anbefalede modeller:
# mistral-small-latest  — hurtig og billig
# mistral-medium-latest — bedre kvalitet
MISTRAL_MODEL=mistral-small-latest

# ── Claude Code (lokal container) ─────────────────────────────────────────────
# Bruges når LLM_PROVIDER=claude-code
# CLAUDE_CODE_HOST=http://claude-code:11578
# CLAUDE_CODE_TIMEOUT=300

# ── Google Tasks ──────────────────────────────────────────────────────────────
# Tasklist ID — find med: docker exec mail-assistant python /app/assistant.py --auth
# @default = standard opgaveliste
GOOGLE_TASKLIST=@default

# Fallback antal dage fra modtagelsesdato hvis LLM ikke finder en frist.
# 0 = forfald i dag, 3 = om 3 dage, 7 = om en uge
DEADLINE_FALLBACK_DAYS=0

# ── Auto-completion af tasks ───────────────────────────────────────────────────
# true = marker udført hvis mailen har fået \Answered flag (dvs. du har besvaret den).
COMPLETE_ON_ANSWERED=true

# true = marker udført hvis mailen er forsvundet fra INBOX og findes i arkivmappen.
COMPLETE_ON_ARCHIVED=true

# ── IMAP flagging ──────────────────────────────────────────────────────────────
# Sæt \Flagged (stjerne/vigtig) på mailen i INBOX hvis LLM-priority matcher.
# Kommasepareret liste: "high", "medium", "low" — tom streng = aldrig flag.
FLAG_ON_PRIORITY=

# ── Scanning ──────────────────────────────────────────────────────────────────
# Startdato for scanning (YYYY-MM-DD).
# Tom = sættes automatisk til i dag ved første kørsel (anbefalet).
SCAN_FROM_DATE=

# Maks mails per kørsel — fordel lasten over dagens kørsler
MAX_MAILS=30

# ── Tidsplan ──────────────────────────────────────────────────────────────────
# Kommaseparerede HH:MM tidspunkter — lokal tid (TZ=Europe/Copenhagen).
SCHEDULE_TIMES=07:00,08:00,09:00,10:00,11:00,12:00,13:00,14:00,15:00,17:00,18:00,19:00,20:00,21:00
